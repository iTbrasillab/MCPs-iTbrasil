# Copie para .env apenas no seu ambiente local. Nao comite segredos reais.

# Use API key quando o Sienge liberar autenticacao por bearer token.
SIENGE_API_KEY=

# Alternativa: basic auth.
SIENGE_USERNAME=
SIENGE_PASSWORD=

# Usado para montar a base URL padrao:
# https://api.sienge.com.br/<subdomain>/public/api/v1
SIENGE_SUBDOMAIN=sua-empresa

# Opcional. Use quando quiser controlar a URL completa.
# Aceita o placeholder {subdomain}.
# SIENGE_BASE_URL=https://api.sienge.com.br/{subdomain}/public/api/v1
SIENGE_BASE_URL=

# Ajuste depois de confirmar o endpoint oficial de criacao de medicao.
SIENGE_MEDICOES_ENDPOINT_PATH=/contracts/measurements

# Endpoint GET read-only usado para validar autenticacao.
SIENGE_AUTH_TEST_ENDPOINT_PATH=/companies

# Timeout em segundos para chamadas REST.
SIENGE_REQUEST_TIMEOUT=30
